<%- include("layouts/header"); -%>
<%- include("layouts/nav"); -%>
<main>

    <h1>Update Order</h1>

    <form action="/update/<%= id %>" method="POST">
        <div>
            <label>Name:</label>
            <input type="text" name="name" value="<%= order.name %>"><br>
        </div>
        <div>
            <label>Email:</label>
            <input type="text" name="email" value="<%= order.email %>"><br>
        </div>
        <div>
            <label>Phone:</label>
            <input type="text" name="phone" value="<%= order.phone %>"><br>
        </div>
        <div>
            <label>Postcode:</label>
            <input type="text" name="postcode" value="<%= order.postcode %>"><br>
        </div>
        <div>
            <label>Tickets:</label>
            <input type="number" name="tickets" value="<%= order.tickets %>"><br>
        </div>
        <div>
            <label>Which Campus</label>
            <select name="campus" id="campus">
                <option value="" <%= order.campus === '----- Select -----' ? 'selected' : '' %>>----- Select -----</option>
                <option value="Doon" <%= order.campus === 'Doon' ? 'selected' : '' %>>Doon</option>
                <option value="Waterloo" <%= order.campus === 'Waterloo' ? 'selected' : '' %>>Waterloo</option>
                <option value="Cambridge" <%= order.campus === 'Cambridge' ? 'selected' : '' %>>Cambridge</option>
            </select>
        </div>

        <div>
            <label>Lunch:</label>
            <select name="lunch">
                <option value="yes" <%= order.lunch === 'yes' ? 'selected' : '' %>>Yes</option>
                <option value="no"  <%= order.lunch === 'no'  ? 'selected' : '' %>>No</option>
            </select><br>
        </div>

        <button type="submit">Update Order</button>
        <% if(typeof(errors) != "undefined") { 
        for(let error of errors) {%>
          <h3><%= error.msg %></h3>

      <%}}%>
    </form>
</main>
<%- include("layouts/footer"); -%>